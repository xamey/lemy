{
  "name": "@lemy/codemode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "start": "wrangler dev --ip 0.0.0.0 --port 8787 --var OPENAPI_SCHEMA_URL:$OPENAPI_SCHEMA_URL --var OPENAPI_BASE_URL:$OPENAPI_BASE_URL --var API_NAME:$API_NAME --var ALLOW_MUTATIONS:$ALLOW_MUTATIONS",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/codemode": "0.4.3",
    "@modelcontextprotocol/sdk": "^1.28.1",
    "agents": "0.17.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260717.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
